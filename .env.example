# ============================================================
# GameXamXi — Environment Variables
# ============================================================
# Copy to .env and fill in real values before deploying.
# For local dev, only apps/worker/.dev.vars and apps/web/.env.local are needed.
# ============================================================

# Cloudflare Configuration
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here

# D1 Database IDs
D1_DATABASE_ID=78f194c2-8672-4913-862e-24cd19a4de76

# KV Namespace IDs — Run these to create:
#   pnpm --filter @gamexamxi/worker exec wrangler kv:namespace create KV_SESSIONS
#   pnpm --filter @gamexamxi/worker exec wrangler kv:namespace create KV_SESSIONS --preview
#   (repeat for KV_CACHE, KV_LEADERBOARD, KV_RATELIMIT)
# Then paste the IDs below AND in apps/worker/wrangler.json
KV_SESSIONS_ID=your_kv_sessions_id
KV_SESSIONS_PREVIEW_ID=your_kv_sessions_preview_id
KV_CACHE_ID=your_kv_cache_id
KV_CACHE_PREVIEW_ID=your_kv_cache_preview_id
KV_LEADERBOARD_ID=your_kv_lb_id
KV_LEADERBOARD_PREVIEW_ID=your_kv_lb_preview_id
KV_RATELIMIT_ID=your_kv_rl_id
KV_RATELIMIT_PREVIEW_ID=your_kv_rl_preview_id

# Worker Secrets (set via `wrangler secret put`, not committed)
# JWT_SECRET=your_super_secret_jwt_key_min_32_chars
# RESEND_API_KEY=re_your_resend_key

# Frontend
NEXT_PUBLIC_API_URL=https://gamexamxi-api.your-subdomain.workers.dev
NEXT_PUBLIC_WS_URL=wss://gamexamxi-api.your-subdomain.workers.dev
