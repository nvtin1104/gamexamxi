---
interface Props {
  logo?: string;
  logoIcon?: string;
  company?: string;
  links?: Array<{ label: string; href: string }>;
}

const {
  logo = 'PlaySoft',
  logoIcon = '🎮',
  company = '2025',
  links = [
    { label: 'Về chúng tôi', href: '/about' },
    { label: 'Điều khoản', href: '/terms' },
    { label: 'Liên hệ', href: '/contact' },
  ],
} = Astro.props;
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-logo">
      <span>{logoIcon}</span> {logo}
    </div>

    <div class="footer-copy">
      © {company} {logo} — Minigame cho mọi người
    </div>

    <div class="footer-links">
      {links.map((link) => (
        <a href={link.href} class="footer-link">
          {link.label}
        </a>
      ))}
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 2px solid var(--color-border);
    padding-top: 32px;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 18px;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .footer-logo span {
    font-size: 20px;
  }

  .footer-copy {
    font-size: 12px;
    color: var(--color-muted);
  }

  .footer-links {
    display: flex;
    gap: 20px;
  }

  .footer-link {
    font-size: 12px;
    color: var(--color-muted);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s;
  }

  .footer-link:hover {
    color: var(--color-ink);
  }

  @media (max-width: 600px) {
    .footer-inner {
      flex-direction: column;
      text-align: center;
    }

    .footer-links {
      justify-content: center;
    }
  }
</style>
