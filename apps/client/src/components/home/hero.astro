---
interface Props {
  playerCount?: number;
  title?: string;
  highlight?: string;
  description?: string;
  primaryBtn?: string;
  secondaryBtn?: string;
  score?: number;
  scoreChange?: number;
  progressData?: Array<{ label: string; value: number; variant: 'sage' | 'peach' | 'sky' }>;
  achievement?: { title: string; subtitle: string };
  showVisual?: boolean;
}

const {
  playerCount = 1240,
  title = 'Minigame',
  highlight = 'vui vẻ',
  description = 'Kho game nhỏ xinh, chơi ngay trên trình duyệt — không cần cài đặt. Thử thách bạn bè, leo bảng xếp hạng!',
  primaryBtn = '🎲 Khám phá game',
  secondaryBtn = '📊 Xếp hạng của tôi',
  score = 48920,
  scoreChange = 2340,
  progressData = [
    { label: 'Word', value: 82, variant: 'sage' as const },
    { label: 'Puzzle', value: 65, variant: 'peach' as const },
    { label: 'Quiz', value: 91, variant: 'sky' as const },
  ],
  achievement = {
    title: 'Thành tích mới!',
    subtitle: 'Xếp hạng top 100 toàn server',
  },
  showVisual = true,
} = Astro.props;
---

<section class="hero">
  <div class="hero-content">
    <div class="hero-badge">
      <span class="badge-dot">●</span>
      {playerCount.toLocaleString()} người đang chơi
    </div>

    <h1 class="hero-title">
      {title}<br />
      <em>{highlight}</em> cho<br />
      mọi người
    </h1>

    <p class="hero-desc">{description}</p>

    <div class="hero-btns">
      <button class="btn btn-primary">
        {primaryBtn}
      </button>
      <button class="btn btn-secondary">
        {secondaryBtn}
      </button>
    </div>
  </div>

  {showVisual && (
    <div class="hero-visual">
      <div class="hero-card">
        <div class="hero-card-label">Điểm hôm nay</div>
        <div class="score-big">{score.toLocaleString()}</div>
        <div class="score-change">
          <span>↑</span> +{scoreChange.toLocaleString()} so với hôm qua
        </div>

        <div class="progress-list">
          {progressData.map((prog) => (
            <div class="prog-row">
              <div class="prog-label">{prog.label}</div>
              <div class="prog-track">
                <div class={`prog-fill ${prog.variant}`} style={`width: ${prog.value}%`} />
              </div>
              <div class="prog-val">{prog.value}%</div>
            </div>
          ))}
        </div>
      </div>

      <div class="hero-card-mini">
        <div class="mini-icon">🏆</div>
        <div>
          <div class="mini-text-top">{achievement.title}</div>
          <div class="mini-text-bot">{achievement.subtitle}</div>
        </div>
        <div class="mini-badge">Mới ✦</div>
      </div>
    </div>
  )}
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: center;
    padding: 20px 0 60px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-sage);
    border: 2px solid var(--color-border);
    border-radius: 30px;
    padding: 5px 14px;
    font-size: 12px;
    font-weight: 600;
    box-shadow: var(--shadow-sm);
    margin-bottom: 20px;
  }

  .badge-dot {
    color: var(--color-sage-dark);
    font-size: 8px;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 58px);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -1.5px;
    margin-bottom: 18px;
  }

  .hero-title em {
    font-style: normal;
    background: var(--color-peach);
    border-bottom: 3px solid var(--color-border);
    padding: 0 6px;
    border-radius: 4px;
  }

  .hero-desc {
    color: var(--color-muted);
    font-size: 16px;
    line-height: 1.65;
    margin-bottom: 32px;
    max-width: 420px;
  }

  .hero-btns {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* Hero Visual */
  .hero-visual {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .hero-card {
    background: var(--color-cream);
    border: 2px solid var(--color-border);
    border-radius: 14px;
    padding: 22px;
    box-shadow: var(--shadow-lg);
    position: relative;
    overflow: hidden;
    animation: floatCard 5s ease-in-out infinite;
  }

  @keyframes floatCard {
    0%, 100% {
      transform: translateY(0) rotate(-0.5deg);
    }
    50% {
      transform: translateY(-8px) rotate(0.5deg);
    }
  }

  .hero-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 6px;
    background: linear-gradient(90deg, var(--color-peach), var(--color-butter), var(--color-sage));
  }

  .hero-card-label {
    font-size: 10px;
    font-weight: 600;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 14px;
    margin-top: 4px;
  }

  .score-big {
    font-family: var(--font-display);
    font-size: 52px;
    font-weight: 800;
    letter-spacing: -2px;
    line-height: 1;
    margin-bottom: 4px;
  }

  .score-change {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: var(--color-sage);
    border: 1.5px solid var(--color-border);
    border-radius: 20px;
    padding: 3px 10px;
    font-size: 12px;
    font-weight: 600;
    box-shadow: 2px 2px 0 var(--color-border);
    margin-bottom: 18px;
  }

  .progress-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .prog-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .prog-label {
    font-size: 12px;
    color: var(--color-muted);
    font-weight: 500;
    width: 58px;
    flex-shrink: 0;
  }

  .prog-track {
    flex: 1;
    height: 10px;
    background: var(--color-sand);
    border: 1.5px solid var(--color-border);
    border-radius: 30px;
    overflow: hidden;
  }

  .prog-fill {
    height: 100%;
    border-radius: 30px;
    transition: width 1.5s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .prog-fill.sage {
    background: var(--color-sage-dark);
  }

  .prog-fill.peach {
    background: var(--color-peach-dark);
  }

  .prog-fill.sky {
    background: var(--color-sky-dark);
  }

  .prog-val {
    font-size: 11px;
    font-weight: 700;
    width: 30px;
    text-align: right;
  }

  /* Mini Card */
  .hero-card-mini {
    background: var(--color-warm);
    border: 2px solid var(--color-border);
    border-radius: 12px;
    padding: 16px 20px;
    box-shadow: var(--shadow-md);
    display: flex;
    align-items: center;
    gap: 14px;
    animation: floatCard2 6s ease-in-out infinite 1s;
  }

  @keyframes floatCard2 {
    0%, 100% {
      transform: translateY(0) rotate(0.3deg);
    }
    50% {
      transform: translateY(-5px) rotate(-0.3deg);
    }
  }

  .mini-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    border: 2px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    flex-shrink: 0;
    background: var(--color-lilac);
  }

  .mini-text-top {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 15px;
    margin-bottom: 3px;
  }

  .mini-text-bot {
    font-size: 12px;
    color: var(--color-muted);
  }

  .mini-badge {
    margin-left: auto;
    background: var(--color-butter);
    border: 1.5px solid var(--color-border);
    border-radius: 20px;
    padding: 3px 10px;
    font-size: 11px;
    font-weight: 700;
    box-shadow: 2px 2px 0 var(--color-border);
  }

  /* Button Styles (inline for Hero) */
  .btn {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14px;
    padding: 13px 28px;
    border: 2px solid var(--color-border);
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.15s;
    letter-spacing: 0.3px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .btn-primary {
    background: var(--color-ink);
    color: var(--color-cream);
    box-shadow: var(--shadow-md);
  }

  .btn-primary:hover {
    transform: translate(-2px, -2px);
    box-shadow: var(--shadow-lg);
  }

  .btn-primary:active {
    transform: translate(2px, 2px);
    box-shadow: none;
  }

  .btn-secondary {
    background: var(--color-cream);
    color: var(--color-ink);
    box-shadow: var(--shadow-md);
  }

  .btn-secondary:hover {
    transform: translate(-2px, -2px);
    box-shadow: var(--shadow-lg);
  }

  .btn-secondary:active {
    transform: translate(2px, 2px);
    box-shadow: none;
  }

  @media (max-width: 760px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .hero-visual {
      display: none;
    }
  }
</style>
