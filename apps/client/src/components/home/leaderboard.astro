---
interface LeaderboardEntry {
  rank: number;
  name: string;
  avatar: string;
  avatarBg?: 'sage' | 'peach' | 'sky' | 'butter' | 'lilac' | 'rose';
  score: number;
  change: number;
  isMe?: boolean;
}

interface Props {
  title?: string;
  entries?: LeaderboardEntry[];
  currentUser?: LeaderboardEntry;
}

const {
  title = '🏆 Bảng xếp hạng',
  entries = [
    { rank: 1, name: 'foxygamer', avatar: '🦊', avatarBg: 'butter', score: 92480, change: 540 },
    { rank: 2, name: 'pengu22', avatar: '🐧', avatarBg: 'sky', score: 88100, change: 210 },
    { rank: 3, name: 'leafwind', avatar: '🌿', avatarBg: 'sage', score: 84650, change: -80 },
    { rank: 4, name: 'sakura_x', avatar: '🌸', avatarBg: 'peach', score: 79340, change: 120 },
  ],
  currentUser = { rank: 12, name: 'Bạn', avatar: '🙂', avatarBg: 'lilac', score: 48920, change: 2340, isMe: true },
} = Astro.props;
---

<div class="panel">
  <div class="panel-title">{title}</div>

  <div class="leaderboard-list">
    {entries.map((entry) => (
      <div class="lb-row">
        <div class={`lb-rank ${entry.rank === 1 ? 'gold' : entry.rank === 2 ? 'silver' : entry.rank === 3 ? 'bronze' : ''}`}>
          {entry.rank}
        </div>
        <div class="lb-avatar" style={`background: var(--color-${entry.avatarBg || 'sage'})`}>
          {entry.avatar}
        </div>
        <div class="lb-name">{entry.name}</div>
        <div>
          <div class="lb-score">{entry.score.toLocaleString()}</div>
          <div class={`lb-change ${entry.change >= 0 ? 'positive' : 'negative'}`}>
            {entry.change >= 0 ? `+${entry.change} ↑` : `${entry.change} ↓`}
          </div>
        </div>
      </div>
    ))}

    {currentUser && (
      <div class="lb-row me">
        <div class="lb-rank">{currentUser.rank}</div>
        <div class="lb-avatar" style={`background: var(--color-${currentUser.avatarBg || 'sage'})`}>
          {currentUser.avatar}
        </div>
        <div class="lb-name">{currentUser.name}</div>
        <div>
          <div class="lb-score">{currentUser.score.toLocaleString()}</div>
          <div class={`lb-change ${currentUser.change >= 0 ? 'positive' : 'negative'}`}>
            {currentUser.change >= 0 ? `+${currentUser.change} ↑` : `${currentUser.change} ↓`}
          </div>
        </div>
      </div>
    )}
  </div>
</div>

<style>
  .panel {
    background: var(--color-cream);
    border: 2px solid var(--color-border);
    border-radius: 14px;
    padding: 24px;
    box-shadow: var(--shadow-lg);
  }

  .panel-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 18px;
    margin-bottom: 18px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .leaderboard-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .lb-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 12px;
    border-radius: 10px;
    transition: background 0.15s;
    cursor: pointer;
    border: 1.5px solid transparent;
  }

  .lb-row:hover {
    background: var(--color-warm);
    border-color: var(--color-border);
  }

  .lb-row.me {
    background: var(--color-butter);
    border-color: var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  .lb-rank {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 16px;
    width: 28px;
    text-align: center;
    flex-shrink: 0;
  }

  .lb-rank.gold {
    color: #c9971a;
  }

  .lb-rank.silver {
    color: #8a8a8a;
  }

  .lb-rank.bronze {
    color: #b06830;
  }

  .lb-avatar {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    border: 2px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }

  .lb-name {
    flex: 1;
    font-weight: 600;
    font-size: 14px;
  }

  .lb-score {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14px;
  }

  .lb-change {
    font-size: 11px;
    font-weight: 600;
  }

  .lb-change.positive {
    color: var(--color-sage-dark);
  }

  .lb-change.negative {
    color: var(--color-peach-dark);
  }
</style>
