---
import StatTile from '../game/stat-tile.astro';

interface StatItem {
  icon: string;
  value: string | number;
  label: string;
  background?: 'sage' | 'peach' | 'sky' | 'butter' | 'lilac' | 'rose';
}

interface Props {
  stats?: StatItem[];
}

const {
  stats = [
    { icon: '🎮', value: 42, label: 'Minigames', background: 'sage' as const },
    { icon: '👥', value: '18k', label: 'Người chơi', background: 'peach' as const },
    { icon: '🏅', value: '230k', label: 'Lượt chơi', background: 'sky' as const },
    { icon: '⭐', value: '4.8', label: 'Đánh giá', background: 'lilac' as const },
  ],
} = Astro.props;
---

<div class="stats-row">
  {stats.map((stat) => (
    <StatTile
      icon={stat.icon}
      value={stat.value}
      label={stat.label}
      background={stat.background || 'sage'}
    />
  ))}
</div>

<style>
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 56px;
  }

  @media (max-width: 760px) {
    .stats-row {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
