---
interface Props {
  name: string;
  id?: string;
  label?: string;
  checked?: boolean;
  disabled?: boolean;
  class?: string;
}

const {
  name,
  id,
  label,
  checked = false,
  disabled = false,
  class: className = '',
} = Astro.props;
---

<label class:list={['checkbox-wrap', disabled && 'disabled', className]}>
  <input
    type="checkbox"
    name={name}
    id={id || name}
    class="checkbox"
    checked={checked}
    disabled={disabled}
  />
  {label && <span class="checkbox-label">{label}</span>}
</label>

<style>
  .checkbox-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
  }

  .checkbox-wrap.disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .checkbox {
    width: 20px;
    height: 20px;
    appearance: none;
    background: var(--color-cream);
    border: 2px solid var(--color-border);
    border-radius: 6px;
    cursor: pointer;
    flex-shrink: 0;
    position: relative;
    box-shadow: var(--shadow-xs);
    transition: background 0.15s;
  }

  .checkbox:checked {
    background: var(--color-sage);
  }

  .checkbox:checked::after {
    content: '✓';
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
  }

  .checkbox-label {
    font-size: 13px;
    font-weight: 500;
  }
</style>
