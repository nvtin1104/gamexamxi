---
interface Props {
  label?: string;
  hint?: string;
  hintType?: 'default' | 'error' | 'success';
  size?: 'sm' | 'default' | 'lg';
  state?: 'default' | 'error' | 'success';
  placeholder?: string;
  type?: 'text' | 'password' | 'email' | 'number' | 'search' | 'tel' | 'url' | 'datetime-local' | 'date' | 'time';
  name?: string;
  id?: string;
  value?: string;
  class?: string;
}

const {
  label,
  hint,
  hintType = 'default',
  size = 'default',
  state = 'default',
  placeholder = '',
  type = 'text',
  name,
  id,
  value,
  class: className = '',
} = Astro.props;

const baseStyles = `
  width: 100%;
  background: var(--color-cream);
  color: var(--color-ink);
  border: 2px solid var(--color-border);
  border-radius: var(--radius-md);
  font-family: var(--font-body);
  font-size: 14px;
  box-shadow: var(--shadow-sm);
  transition: box-shadow 0.15s, border-color 0.15s;
  outline: none;
`;

const sizeStyles = {
  sm: 'padding: 7px 12px; font-size: 13px;',
  default: 'padding: 10px 14px;',
  lg: 'padding: 13px 18px; font-size: 15px;',
};

const stateStyles = {
  default: '',
  error: 'border-color: var(--color-rose-dark); background: var(--color-rose-light);',
  success: 'border-color: var(--color-sage-dark); background: var(--color-sage-light);',
};
---

{label && (
  <label class="input-label" for={id || name}>
    {label}
  </label>
)}

<input
  type={type}
  name={name}
  id={id || name}
  value={value}
  placeholder={placeholder}
  class:list={['input', `input-${size}`, `input-${state}`, className]}
  style={`${baseStyles} ${sizeStyles[size]} ${stateStyles[state]}`}
/>

{hint && (
  <span class:list={['input-hint', hintType]}>
    {hintType === 'error' && '✗ '}
    {hintType === 'success' && '✓ '}
    {hint}
  </span>
)}

<style>
  .input:focus {
    box-shadow: var(--shadow-md);
  }

  .input::placeholder {
    color: var(--color-subtle);
  }

  .input-label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.3px;
    display: block;
    margin-bottom: 6px;
  }

  .input-hint {
    font-size: 11px;
    color: var(--color-muted);
  }

  .input-hint.error {
    color: var(--color-rose-dark);
  }

  .input-hint.success {
    color: var(--color-sage-dark);
  }
</style>
