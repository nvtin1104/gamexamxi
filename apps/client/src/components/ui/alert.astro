---
interface Props {
  variant?: 'info' | 'success' | 'warning' | 'error';
  icon?: string;
  title?: string;
  class?: string;
}

const {
  variant = 'info',
  icon,
  title,
  class: className = '',
} = Astro.props;

const variantStyles = {
  info: 'background: var(--color-sky-light);',
  success: 'background: var(--color-sage-light);',
  warning: 'background: var(--color-butter-light);',
  error: 'background: var(--color-rose-light);',
};

const defaultIcons = {
  info: '💡',
  success: '✅',
  warning: '⚠️',
  error: '❌',
};
---

<div class:list={['alert', `alert-${variant}`, className]} style={variantStyles[variant]}>
  <div class="alert-icon">{icon || defaultIcons[variant]}</div>
  <div class="alert-content">
    {title && <div class="alert-title">{title}</div>}
    <div class="alert-desc">
      <slot />
    </div>
  </div>
</div>

<style>
  .alert {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    padding: 14px 16px;
    border: 2px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .alert-icon {
    font-size: 18px;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .alert-title {
    font-weight: 700;
    font-size: 14px;
    margin-bottom: 3px;
  }

  .alert-desc {
    font-size: 13px;
    color: var(--color-muted);
  }
</style>
