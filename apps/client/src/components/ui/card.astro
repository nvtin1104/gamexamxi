---
interface Props {
  variant?: 'default' | 'flat' | 'raised' | 'colored-top';
  background?: 'cream' | 'warm' | 'sage-light' | 'peach-light' | 'sky-light' | 'butter-light' | 'lilac-light' | 'rose-light';
  class?: string;
}

const {
  variant = 'default',
  background = 'cream',
  class: className = '',
} = Astro.props;

const baseStyles = `
  background: var(--color-cream);
  border: 2px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 20px;
  transition: transform 0.2s, box-shadow 0.2s;
  cursor: default;
`;

const variantStyles = {
  default: 'box-shadow: var(--shadow-md);',
  flat: 'box-shadow: none;',
  raised: 'box-shadow: var(--shadow-lg);',
  'colored-top': 'padding-top: 0; overflow: hidden; box-shadow: var(--shadow-md);',
};

const bgStyles = {
  cream: 'background: var(--color-cream);',
  warm: 'background: var(--color-warm);',
  'sage-light': 'background: var(--color-sage-light);',
  'peach-light': 'background: var(--color-peach-light);',
  'sky-light': 'background: var(--color-sky-light);',
  'butter-light': 'background: var(--color-butter-light);',
  'lilac-light': 'background: var(--color-lilac-light);',
  'rose-light': 'background: var(--color-rose-light);',
};
---

<div
  class:list={['card', `card-${variant}`, className]}
  style={`${baseStyles} ${variantStyles[variant]} ${bgStyles[background]}`}
>
  <slot />
</div>

<style>
  .card:hover {
    transform: translate(-3px, -3px);
  }

  .card-default:hover,
  .card-colored-top:hover {
    box-shadow: var(--shadow-lg);
  }

  .card-flat:hover {
    box-shadow: var(--shadow-md);
    transform: translate(-2px, -2px);
  }

  .card-raised:hover {
    box-shadow: var(--shadow-xl);
  }
</style>
