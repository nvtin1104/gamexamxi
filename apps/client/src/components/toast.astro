---
export interface ToastProps {
  message: string;
  type?: 'success' | 'error' | 'info' | 'warning';
  duration?: number;
}

const toastIcons = {
  success: '✅',
  error: '❌',
  warning: '⚠️',
  info: '💡',
};

const toastStyles = {
  success: { bg: 'var(--sage-l, #dcfce7)', border: 'var(--sage, #22c55e)' },
  error: { bg: 'var(--rose-l, #ffe4e6)', border: 'var(--rose, #f43f5e)' },
  warning: { bg: 'var(--butter-l, #fef9c3)', border: 'var(--butter, #facc15)' },
  info: { bg: 'var(--sky-l, #e0f2fe)', border: 'var(--sky, #0ea5e9)' },
};

const defaultDuration = 3000;
---

<div id="toast-container"></div>

<script define:vars={{ toastIcons, toastStyles, defaultDuration }}>
  class Toast {
    static show(message, options = {}) {
      const { type = 'info', duration = defaultDuration } = options;
      const container = document.getElementById('toast-container');
      
      const toast = document.createElement('div');
      toast.className = 'toast';
      toast.style.setProperty('--toast-bg', toastStyles[type].bg);
      toast.style.setProperty('--toast-border', toastStyles[type].border);
      
      toast.innerHTML = `
        <div class="toast-icon">${toastIcons[type]}</div>
        <div class="toast-message">${message}</div>
        <button class="toast-close" aria-label="Đóng">×</button>
      `;
      
      container.appendChild(toast);
      
      // Animate in
      requestAnimationFrame(() => {
        toast.classList.add('toast-show');
      });
      
      // Close button
      const closeBtn = toast.querySelector('.toast-close');
      closeBtn.addEventListener('click', () => this.remove(toast));
      
      // Auto remove
      if (duration > 0) {
        setTimeout(() => this.remove(toast), duration);
      }
    }
    
    static remove(toast) {
      toast.classList.remove('toast-show');
      toast.classList.add('toast-hide');
      setTimeout(() => toast.remove(), 200);
    }
    
    static success(message, duration) {
      this.show(message, { type: 'success', duration });
    }
    
    static error(message, duration) {
      this.show(message, { type: 'error', duration });
    }
    
    static warning(message, duration) {
      this.show(message, { type: 'warning', duration });
    }
    
    static info(message, duration) {
      this.show(message, { type: 'info', duration });
    }
  }
  
  // Expose globally
  window.toast = Toast;
</script>

<style is:global>
  #toast-container {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 10px;
    pointer-events: none;
  }
  
  .toast {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    background: var(--toast-bg, #faf7f2);
    border: 2px solid var(--toast-border, #1a1a1a);
    border-radius: 10px;
    box-shadow: 3px 3px 0 var(--toast-border, #1a1a1a);
    font-size: 14px;
    font-weight: 500;
    min-width: 240px;
    max-width: 360px;
    pointer-events: auto;
    transform: translateX(120%);
    transition: transform 0.2s ease-out;
  }
  
  .toast.toast-show {
    transform: translateX(0);
  }
  
  .toast.toast-hide {
    transform: translateX(120%);
    transition: transform 0.2s ease-in;
  }
  
  .toast-icon {
    font-size: 18px;
    flex-shrink: 0;
  }
  
  .toast-message {
    flex: 1;
    color: var(--color-ink, #1a1a1a);
  }
  
  .toast-close {
    background: none;
    border: none;
    font-size: 20px;
    cursor: pointer;
    color: var(--color-muted, #666);
    padding: 0;
    line-height: 1;
    flex-shrink: 0;
  }
  
  .toast-close:hover {
    color: var(--color-ink, #1a1a1a);
  }
</style>
