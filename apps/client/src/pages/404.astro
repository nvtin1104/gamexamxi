---
import PageLayout from '../layouts/PageLayout.astro';
import Card from '../components/ui/card.astro';
import Button from '../components/ui/button.astro';
---

<PageLayout title="404 - Không tìm thấy trang">
  <div class="notfound">
    <Card variant="raised" background="warm" class="notfound-card">
      <div class="notfound-icon">🧭</div>
      <div class="notfound-code">404</div>
      <div class="notfound-title">Trang không tồn tại</div>
      <div class="notfound-desc">
        Có vẻ như bạn đã lạc đường rồi. Trang này đã bị thất lạc hoặc không tồn tại.
      </div>
      <Button variant="butter" size="md" shape="pill">
        <a href="/">← Về trang chủ</a>
      </Button>
    </Card>
  </div>
</PageLayout>

<style>
  .notfound {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
  }

  .notfound-card {
    text-align: center;
    max-width: 420px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .notfound-icon {
    font-size: 56px;
    margin-bottom: 16px;
  }

  .notfound-code {
    font-family: var(--font-display);
    font-size: 72px;
    font-weight: 800;
    line-height: 1;
    color: var(--color-ink);
    margin-bottom: 8px;
  }

  .notfound-title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    color: var(--color-ink);
    margin-bottom: 12px;
  }

  .notfound-desc {
    font-size: 14px;
    color: var(--color-muted);
    margin-bottom: 28px;
    line-height: 1.6;
  }

  .notfound-card :global(a) {
    text-decoration: none;
    color: inherit;
  }

  @media (max-width: 480px) {
    .notfound-code {
      font-size: 56px;
    }

    .notfound-icon {
      font-size: 44px;
    }
  }
</style>
