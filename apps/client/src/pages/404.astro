---
import PageLayout from '../layouts/PageLayout.astro';
import Card from '../components/ui/card.astro';
import Button from '../components/ui/button.astro';
---

<PageLayout title="404 - Không tìm thấy trang">
  <div class="notfound">
    <Card variant="raised" background="butter-light" class="notfound-card">
      <div class="notfound-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M16 16s-1.5-2-4-2-4 2-4 2"/>
          <line x1="9" y1="9" x2="9.01" y2="9"/>
          <line x1="15" y1="9" x2="15.01" y2="9"/>
        </svg>
      </div>
      <div class="notfound-code">404</div>
      <div class="notfound-title">Không tìm thấy trang</div>
      <div class="notfound-desc">
        Có vẻ như bạn đã lạc đường rồi. Trang này đã bị thất lạc hoặc không tồn tại.
      </div>
      <div class="notfound-actions">
        <Button variant="primary" size="lg" shape="pill">
          <a href="/">Về trang chủ</a>
        </Button>
        <Button variant="secondary" size="lg" shape="pill" onclick="window.history.back()">
          Quay lại
        </Button>
      </div>
    </Card>
  </div>
</PageLayout>

<style>
  .notfound {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
    padding: 20px;
  }

  .notfound-card {
    text-align: center;
    max-width: 440px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 48px 32px;
  }

  .notfound-icon {
    color: var(--color-ink);
    margin-bottom: 16px;
    opacity: 0.7;
  }

  .notfound-code {
    font-family: var(--font-display);
    font-size: 80px;
    font-weight: 900;
    line-height: 1;
    color: var(--color-ink);
    letter-spacing: -2px;
    margin-bottom: 8px;
  }

  .notfound-title {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 800;
    color: var(--color-ink);
    margin-bottom: 12px;
    letter-spacing: -0.3px;
  }

  .notfound-desc {
    font-size: 14px;
    color: var(--color-muted);
    margin-bottom: 32px;
    line-height: 1.6;
    max-width: 320px;
  }

  .notfound-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .notfound-card :global(a) {
    text-decoration: none;
    color: inherit;
  }

  @media (max-width: 480px) {
    .notfound-code {
      font-size: 64px;
    }

    .notfound-icon {
      transform: scale(0.85);
    }

    .notfound-card {
      padding: 32px 24px;
    }

    .notfound-actions {
      flex-direction: column;
      width: 100%;
    }

    .notfound-actions :global(button),
    .notfound-actions :global(a) {
      width: 100%;
    }
  }
</style>
