---
import PageLayout from '../layouts/PageLayout.astro';

interface PickemEvent {
  id: string;
  title: string;
  thumbnail: string;
  description: string;
  eventDate: string;
  closePicksAt: string;
  status: 'upcoming' | 'active' | 'closed';
  participants: number;
  winPoints: number;
  pickExp: number;
  options?: PickemOption[];
}

interface PickemOption {
  id: string;
  label: string;
  odds?: number;
  votes?: number;
  percentage?: number;
}

