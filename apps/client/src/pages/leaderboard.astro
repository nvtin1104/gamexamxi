---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/header.astro';
import Footer from '../components/layout/footer.astro';
import '../styles/global.css';

interface LeaderboardEntry {
  rank: number;
  name: string;
  avatar: string;
  avatarBg: 'sage' | 'peach' | 'sky' | 'butter' | 'lilac' | 'rose';
  score: number;
  change: number;
  isMe?: boolean;
}

const allTimeEntries: LeaderboardEntry[] = [
  { rank: 1, name: 'foxygamer', avatar: '🦊', avatarBg: 'butter', score: 92480, change: 540 },
  { rank: 2, name: 'pengu22', avatar: '🐧', avatarBg: 'sky', score: 88100, change: 210 },
  { rank: 3, name: 'leafwind', avatar: '🌿', avatarBg: 'sage', score: 84650, change: -80 },
  { rank: 4, name: 'sakura_x', avatar: '🌸', avatarBg: 'peach', score: 79340, change: 120 },
  { rank: 5, name: 'dragon_k', avatar: '🐉', avatarBg: 'rose', score: 75120, change: 340 },
  { rank: 6, name: 'neo_hunter', avatar: '🎯', avatarBg: 'lilac', score: 72300, change: -150 },
  { rank: 7, name: 'pixel_m', avatar: '👾', avatarBg: 'sage', score: 68900, change: 80 },
  { rank: 8, name: 'star_lord', avatar: '⭐', avatarBg: 'butter', score: 65400, change: 220 },
  { rank: 9, name: 'moon_cat', avatar: '🐱', avatarBg: 'sky', score: 62100, change: -40 },
  { rank: 10, name: 'cosmo_x', avatar: '🚀', avatarBg: 'peach', score: 58900, change: 160 },
];

const weeklyEntries: LeaderboardEntry[] = [
  { rank: 1, name: 'newbie_99', avatar: '🆕', avatarBg: 'sage', score: 12480, change: 2540 },
  { rank: 2, name: 'quick_finger', avatar: '⚡', avatarBg: 'butter', score: 11200, change: 1810 },
  { rank: 3, name: 'brain_storm', avatar: '🧠', avatarBg: 'lilac', score: 10800, change: 950 },
  { rank: 4, name: 'game_master', avatar: '🎮', avatarBg: 'sky', score: 9950, change: 720 },
  { rank: 5, name: 'champ_22', avatar: '🏆', avatarBg: 'peach', score: 8900, change: 340 },
];

const currentUser = { rank: 42, name: 'Bạn', avatar: '🙂', avatarBg: 'lilac', score: 4892, change: 234, isMe: true };

const tabs = [
  { id: 'all-time', label: 'Tất cả thời gian', active: true },
  { id: 'weekly', label: 'Tuần này', active: false },
  { id: 'daily', label: 'Hôm nay', active: false },
];
---

<Layout title="Bảng xếp hạng - PlaySoft">
  <div class="page">
    <Header />

    <main class="leaderboard-page">
      <div class="page-header">
        <h1 class="page-title">🏆 Bảng xếp hạng</h1>
        <p class="page-desc">So sánh điểm số của bạn với các người chơi khác</p>
      </div>

      <div class="tabs">
        {tabs.map((tab) => (
          <button class:list={['tab', tab.active && 'active']}>
            {tab.label}
          </button>
        ))}
      </div>

      <div class="leaderboard-card">
        <div class="top-3">
          <div class="podium-item second">
            <div class="podium-avatar" style="background: var(--color-sky)">🐧</div>
            <div class="podium-rank">2</div>
            <div class="podium-name">pengu22</div>
            <div class="podium-score">88,100</div>
          </div>
          <div class="podium-item first">
            <div class="crown">👑</div>
            <div class="podium-avatar" style="background: var(--color-butter)">🦊</div>
            <div class="podium-rank">1</div>
            <div class="podium-name">foxygamer</div>
            <div class="podium-score">92,480</div>
          </div>
          <div class="podium-item third">
            <div class="podium-avatar" style="background: var(--color-sage)">🌿</div>
            <div class="podium-rank">3</div>
            <div class="podium-name">leafwind</div>
            <div class="podium-score">84,650</div>
          </div>
        </div>

        <div class="leaderboard-list">
          {allTimeEntries.slice(3).map((entry) => (
            <div class="lb-row">
              <div class="lb-rank">{entry.rank}</div>
              <div class="lb-avatar" style={`background: var(--color-${entry.avatarBg})`}>
                {entry.avatar}
              </div>
              <div class="lb-name">{entry.name}</div>
              <div class="lb-score">{entry.score.toLocaleString()}</div>
              <div class={`lb-change ${entry.change >= 0 ? 'positive' : 'negative'}`}>
                {entry.change >= 0 ? `+${entry.change} ↑` : `${entry.change} ↓`}
              </div>
            </div>
          ))}

          <div class="lb-row me">
            <div class="lb-rank">{currentUser.rank}</div>
            <div class="lb-avatar" style={`background: var(--color-${currentUser.avatarBg})`}>
              {currentUser.avatar}
            </div>
            <div class="lb-name">{currentUser.name}</div>
            <div class="lb-score">{currentUser.score.toLocaleString()}</div>
            <div class={`lb-change ${currentUser.change >= 0 ? 'positive' : 'negative'}`}>
              {currentUser.change >= 0 ? `+${currentUser.change} ↑` : `${currentUser.change} ↓`}
            </div>
          </div>
        </div>
      </div>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .page {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }

  .leaderboard-page {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .page-header {
    text-align: center;
    padding: 20px 0;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 800;
    letter-spacing: -1px;
    margin-bottom: 8px;
  }

  .page-desc {
    color: var(--color-muted);
    font-size: 16px;
  }

  .tabs {
    display: flex;
    gap: 8px;
    justify-content: center;
    margin-bottom: 8px;
  }

  .tab {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 13px;
    padding: 10px 20px;
    border: 2px solid var(--color-border);
    border-radius: 30px;
    background: var(--color-cream);
    color: var(--color-muted);
    cursor: pointer;
    transition: all 0.2s;
  }

  .tab:hover {
    background: var(--color-warm);
  }

  .tab.active {
    background: var(--color-ink);
    color: var(--color-cream);
    border-color: var(--color-ink);
  }

  .leaderboard-card {
    background: var(--color-cream);
    border: 2px solid var(--color-border);
    border-radius: 16px;
    padding: 32px;
    box-shadow: var(--shadow-lg);
  }

  .top-3 {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    gap: 16px;
    margin-bottom: 32px;
    padding-bottom: 24px;
    border-bottom: 2px solid var(--color-sand);
  }

  .podium-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .podium-item.first {
    order: 2;
  }

  .podium-item.second {
    order: 1;
  }

  .podium-item.third {
    order: 3;
  }

  .crown {
    font-size: 28px;
    margin-bottom: -8px;
    z-index: 1;
  }

  .podium-avatar {
    width: 64px;
    height: 64px;
    border-radius: 14px;
    border: 3px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    box-shadow: var(--shadow-md);
  }

  .podium-rank {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 20px;
  }

  .podium-item.first .podium-rank {
    color: #c9971a;
  }

  .podium-item.second .podium-rank {
    color: #8a8a8a;
  }

  .podium-item.third .podium-rank {
    color: #b06830;
  }

  .podium-name {
    font-weight: 600;
    font-size: 14px;
  }

  .podium-score {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 16px;
    color: var(--color-muted);
  }

  .podium-item.first .podium-avatar {
    width: 80px;
    height: 80px;
    font-size: 36px;
  }

  .leaderboard-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .lb-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: 12px;
    transition: background 0.15s;
    border: 2px solid transparent;
  }

  .lb-row:hover {
    background: var(--color-warm);
    border-color: var(--color-border);
  }

  .lb-row.me {
    background: var(--color-butter);
    border-color: var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  .lb-rank {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 16px;
    width: 32px;
    text-align: center;
    flex-shrink: 0;
  }

  .lb-avatar {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    border: 2px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
  }

  .lb-name {
    flex: 1;
    font-weight: 600;
    font-size: 15px;
  }

  .lb-score {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 15px;
    min-width: 80px;
    text-align: right;
  }

  .lb-change {
    font-size: 12px;
    font-weight: 600;
    min-width: 80px;
    text-align: right;
  }

  .lb-change.positive {
    color: var(--color-sage-dark);
  }

  .lb-change.negative {
    color: var(--color-peach-dark);
  }

  @media (max-width: 600px) {
    .top-3 {
      gap: 8px;
    }

    .podium-avatar {
      width: 48px;
      height: 48px;
      font-size: 20px;
    }

    .podium-item.first .podium-avatar {
      width: 60px;
      height: 60px;
      font-size: 28px;
    }

    .leaderboard-card {
      padding: 16px;
    }
  }
</style>
