---
import Header from '../components/layout/header.astro';
import Footer from '../components/layout/footer.astro';
import Toast from '../components/toast.astro';
import '../styles/global.css';

interface Props {
  title: string;
  googleClientId?: string;
  apiUrl?: string;
}

const { 
  title,
  googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || '',
  apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:8787'
} = Astro.props;
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="page">
      <Header googleClientId={googleClientId} apiUrl={apiUrl} />
      <main>
        <slot />
      </main>
      <Footer />
      <Toast />
    </div>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }

  .page {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }

  main {
    display: flex;
    flex-direction: column;
  }
</style>
