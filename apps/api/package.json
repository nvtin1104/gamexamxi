{
  "name": "@gamexamxi/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply gamexamxi-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply gamexamxi-db --remote"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "drizzle-orm": "^0.35.0",
    "hono": "^4.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241018.0",
    "drizzle-kit": "^0.25.0",
    "typescript": "^5.6.0",
    "wrangler": "^3.80.0"
  }
}
