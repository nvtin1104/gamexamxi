---
import DashboardLayout from '@/layouts/DashboardLayout.astro'
---

<DashboardLayout title="Cài đặt">
  <div class="space-y-6">
    <div>
      <h1 class="text-3xl font-bold tracking-tight">Cài đặt</h1>
      <p class="text-muted-foreground">Quản lý cài đặt ứng dụng của bạn.</p>
    </div>

    <div class="rounded-lg border bg-card p-6 text-card-foreground">
      <h2 class="text-lg font-semibold">Cài đặt chung</h2>
      <p class="mt-2 text-sm text-muted-foreground">
        Trang cài đặt đang được phát triển. Cấu hình tuỳ chọn ứng dụng của bạn tại đây.
      </p>
    </div>
  </div>
</DashboardLayout>
