---
import DashboardLayout from '@/layouts/DashboardLayout.astro'
import { StatsCards } from '@/components/dashboard/StatsCards'
import { RevenueChart } from '@/components/dashboard/RevenueChart'
import { RecentSales } from '@/components/dashboard/RecentSales'
---

<DashboardLayout title="Tổng quan">
	<div class="space-y-6">
		<div>
			<h1 class="text-2xl font-bold tracking-tight">Tổng quan</h1>
			<p class="text-muted-foreground text-sm">
				Chào mừng trở lại! Đây là những gì đang xảy ra với hệ thống của bạn hôm nay.
			</p>
		</div>

		<StatsCards client:load />

		<div class="grid gap-4 md:grid-cols-2 lg:grid-cols-7">
			<RevenueChart client:load />
			<RecentSales client:load />
		</div>
	</div>
</DashboardLayout>
