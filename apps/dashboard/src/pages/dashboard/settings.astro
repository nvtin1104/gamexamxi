---
import DashboardLayout from '@/layouts/DashboardLayout.astro'
---

<DashboardLayout title="Settings">
  <div class="space-y-6">
    <div>
      <h1 class="text-3xl font-bold tracking-tight">Settings</h1>
      <p class="text-muted-foreground">Manage your application settings.</p>
    </div>

    <div class="rounded-lg border bg-card p-6 text-card-foreground">
      <h2 class="text-lg font-semibold">General Settings</h2>
      <p class="mt-2 text-sm text-muted-foreground">
        Settings page coming soon. Configure your application preferences here.
      </p>
    </div>
  </div>
</DashboardLayout>
