---
import '@/styles/globals.css'
import { DashboardShell } from '@/components/DashboardShell'

interface Props {
  title: string
}

const { title } = Astro.props

// Server-side auth guard: redirect to /login if not authenticated
const loggedIn = Astro.cookies.get('logged_in')
if (!loggedIn?.value) {
  return Astro.redirect('/login')
}

// Read sidebar state from cookie to prevent layout shift
const sidebarCookie = Astro.cookies.get('sidebar_state')
const defaultSidebarOpen = sidebarCookie?.value !== 'false'
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Gamexamxi Dashboard</title>
    <meta name="description" content="Gamexamxi Admin Dashboard" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- FOUC prevention: apply theme before first paint -->
    <script is:inline>
      ;(function () {
        try {
          var theme = localStorage.getItem('theme')
          if (theme === 'light') {
            document.documentElement.classList.remove('dark')
          } else {
            document.documentElement.classList.add('dark')
          }
        } catch (_) {
          document.documentElement.classList.add('dark')
        }
      })()
    </script>
  </head>
  <body class="min-h-screen bg-background font-sans antialiased">
    <DashboardShell title={title} defaultOpen={defaultSidebarOpen} client:load>
      <slot />
    </DashboardShell>
  </body>
</html>


