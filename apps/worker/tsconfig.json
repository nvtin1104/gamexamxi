{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@gamexamxi/shared": ["../../packages/shared/src/index.ts"],
      "@gamexamxi/db": ["../../packages/db/src/index.ts"],
      "@gamexamxi/db/schema": ["../../packages/db/src/schema/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
