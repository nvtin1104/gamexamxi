{
  "name": "gamexamxi",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @gamexamxi/api dev",
    "dev:dashboard": "pnpm --filter @gamexamxi/dashboard dev",
    "dev:client": "pnpm --filter @gamexamxi/client dev",
    "dev:website": "pnpm --filter @gamexamxi/website dev",
    "dev":  "turbo dev --filter=@gamexamxi/website --filter=@gamexamxi/dashboard --filter=@gamexamxi/api",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @gamexamxi/api db:generate",
    "db:migrate": "pnpm --filter @gamexamxi/api db:migrate"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
